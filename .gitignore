.env

# -----------------------------
# Project-specific (important for YOU)
# -----------------------------
# Ignore generated pixel outputs
output/
outputs/

# Ignore random test images (keep only screenshots folder)
test_images/
input_images/

# BUT keep your demo screenshots
!screenshots/